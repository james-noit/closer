meta {
  name: Closer Backend - Persona CRUD
}

auth {
  mode: bearer
  token: "{{authToken}}"
}

vars:pre-request {
  baseUrl: http://localhost:8080
  personaId: 
  authToken: 
  loginUsername: localuser
  loginPassword: secret
  otherUsername: otheruser
  otherPassword: secret
}

docs {
  Bateria basica de pruebas para el CRUD HATEOAS de Persona.
}
