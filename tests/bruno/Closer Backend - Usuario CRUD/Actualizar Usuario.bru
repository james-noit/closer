meta {
  name: Actualizar Usuario
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/api/usuarios/{{usuarioId}}
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "user2",
    "password": "newsecret",
    "persona": null
  }
}

script:post-response {
  test('Status 200', function () {
      expect(res.getStatus()).to.equal(200);
  });
  test('Username actualizado', function () {
      var data = res.getBody();
      expect(data.username).to.eql('user2');
  });
}

settings {
  encodeUrl: true
}