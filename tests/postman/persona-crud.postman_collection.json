{
  "info": {
    "name": "Closer Backend - JWT + CRUD",
    "description": "Coleccion para probar login JWT, refresh token y CRUD de Persona/Usuario.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{loginUsername}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('authToken', data.token);",
              "pm.collectionVariables.set('refreshToken', data.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Refresh",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "refresh"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('authToken', data.token);",
              "pm.collectionVariables.set('refreshToken', data.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "Persona - Crear",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Ana\",\n  \"apellidos\": \"Lopez\",\n  \"numeroTelefono\": \"+34123456789\",\n  \"fechaCumpleanos\": \"1992-06-15\",\n  \"email\": \"ana.lopez@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/personas",
          "host": ["{{baseUrl}}"],
          "path": ["api", "personas"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('personaId', data.id || (data._links && data._links.self && data._links.self.href && data._links.self.href.split('/').pop()));"
            ]
          }
        }
      ]
    },
    {
      "name": "Persona - Listar",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/personas",
          "host": ["{{baseUrl}}"],
          "path": ["api", "personas"]
        }
      }
    },
    {
      "name": "Persona - Obtener por ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/personas/{{personaId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "personas", "{{personaId}}"]
        }
      }
    },
    {
      "name": "Persona - Actualizar",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Ana Maria\",\n  \"apellidos\": \"Lopez Perez\",\n  \"numeroTelefono\": \"+34999888777\",\n  \"fechaCumpleanos\": \"1992-06-15\",\n  \"email\": \"ana.maria@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/personas/{{personaId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "personas", "{{personaId}}"]
        }
      }
    },
    {
      "name": "Persona - Eliminar",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/personas/{{personaId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "personas", "{{personaId}}"]
        }
      }
    },
    {
      "name": "Usuario - Crear",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"secret\",\n  \"persona\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/usuarios",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('usuarioId', data.id || (data._links && data._links.self && data._links.self.href && data._links.self.href.split('/').pop()));"
            ]
          }
        }
      ]
    },
    {
      "name": "Usuario - Listar",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/usuarios",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios"]
        }
      }
    },
    {
      "name": "Usuario - Obtener por ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/{{usuarioId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios", "{{usuarioId}}"]
        }
      }
    },
    {
      "name": "Usuario - Actualizar",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"user2\",\n  \"password\": \"newsecret\",\n  \"persona\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/{{usuarioId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios", "{{usuarioId}}"]
        }
      }
    },
    {
      "name": "Usuario - Eliminar",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/{{usuarioId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "usuarios", "{{usuarioId}}"]
        }
      }
    },
    {
      "name": "Auth - Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "logout"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "loginUsername", "value": "localuser" },
    { "key": "loginPassword", "value": "secret" },
    { "key": "authToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "personaId", "value": "" },
    { "key": "usuarioId", "value": "" }
  ]
}
