meta {
  name: Crear Usuario
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/usuarios
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "user1",
    "password": "secret",
    "persona": null
  }
}

script:post-response {
  test('Status 201', function () {
      expect(res.getStatus()).to.equal(201);
  });
  var data = res.getBody();
  bru.setVar('usuarioId', data.id);
}

settings {
  encodeUrl: true
}