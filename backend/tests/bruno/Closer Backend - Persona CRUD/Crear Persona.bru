meta {
  name: Crear Persona
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/personas
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "nombre": "Ana",
    "apellidos": "Lopez",
    "numeroTelefono": "+34123456789",
    "fechaCumpleanos": "1992-06-15",
    "email": "ana.lopez@example.com"
  }
}

script:post-response {
  test('Status 201', function () {
      expect(res.getStatus()).to.equal(201);
  });
  var data = res.getBody();
  bru.setVar('personaId', data.id);
}

settings {
  encodeUrl: true
}
