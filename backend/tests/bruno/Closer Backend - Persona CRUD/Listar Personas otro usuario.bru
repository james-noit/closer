meta {
  name: Listar Personas otro usuario
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/api/personas
  auth: inherit
}

script:post-response {
  test('Status 200', function () {
      expect(res.getStatus()).to.equal(200);
  });
  test('Otro usuario no ve personas ajenas', function () {
      var data = res.getBody();
      if (data._embedded) {
          expect(data._embedded.personas).to.be.an('array').that.is.empty;
      } else {
          expect(data._embedded).to.be.undefined;
      }
  });
}

settings {
  encodeUrl: true
}