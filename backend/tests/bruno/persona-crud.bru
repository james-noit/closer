{
  "info": {
    "name": "Closer Backend - Persona CRUD",
    "description": "Bateria basica de pruebas para el CRUD HATEOAS de Persona.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Crear Persona",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Ana\",\n  \"apellidos\": \"Lopez\",\n  \"numeroTelefono\": \"+34123456789\",\n  \"fechaCumpleanos\": \"1992-06-15\",\n  \"email\": \"ana.lopez@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/personas",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "personas"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "var data = pm.response.json();",
              "pm.collectionVariables.set('personaId', data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Listar Personas",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/personas",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "personas"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Obtener Persona por ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/personas/{{personaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "personas",
            "{{personaId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Actualizar Persona",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Ana Maria\",\n  \"apellidos\": \"Lopez Perez\",\n  \"numeroTelefono\": \"+34999888777\",\n  \"fechaCumpleanos\": \"1992-06-15\",\n  \"email\": \"ana.maria@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/personas/{{personaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "personas",
            "{{personaId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Nombre actualizado', function () {",
              "    var data = pm.response.json();",
              "    pm.expect(data.nombre).to.eql('Ana Maria');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Eliminar Persona",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/api/personas/{{personaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "personas",
            "{{personaId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 204', function () {",
              "    pm.response.to.have.status(204);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Comprobar 404 tras eliminar",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/personas/{{personaId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "personas",
            "{{personaId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "personaId",
      "value": ""
    }
  ]
}
